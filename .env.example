# ───────────────────────────── Smriti environment ─────────────────────────────
# Copy this file to `.env` (git-ignored) and fill it in. Every key stays server-side.
#
#   cp .env.example .env
#
# ── REQUIRED: Claude (the AI brain — journal analysis, chat, next-move) ──
ANTHROPIC_API_KEY=
# Optional hard override. Leave BLANK to let the server route per task
# (Haiku for chat/next-action, Sonnet for analysis). Set only to force one model.
ANTHROPIC_MODEL=

# ── REQUIRED for voice: AssemblyAI Voice Agent API ──
# The browser never sees this — the server mints a short-lived token from it.
# Get one at https://www.assemblyai.com/dashboard (free credits on signup).
ASSEMBLYAI_API_KEY=

# ── OPTIONAL fallback: Gemini via Google Vertex AI (uses GCP credits) ──
# Only used if ANTHROPIC_API_KEY is absent. Safe to leave blank.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
# Service-account JSON on one line (or base64), OR a path via GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_VERTEX_CREDENTIALS=
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# ── OPTIONAL last-resort fallback: Gemini Developer API key (NOT GCP credits) ──
GEMINI_API_KEY=
GEMINI_MODEL=

# Server port (default 5599)
PORT=5599
